NODE_ENV=development
PORT=5000

MONGO_URI=mongodb+srv://<username>:<password>@cluster0.bibg1vo.mongodb.net/myDB
MONGO_DB_NAME=myDB

# Firebase Admin credentials (use one method below)
# Method 0: service account JSON file path (relative to /server or absolute)
